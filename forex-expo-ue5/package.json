{
  "name": "forex-expo-ue5",
  "version": "1.0.0",
  "description": "Forex Expo Dubai — UE5 Pixel Streaming Virtual Exhibition Hall",
  "private": true,
  "scripts": {
    "install:all": "npm i && cd server && npm i && cd ../client && npm i",
    "server": "cd server && npm start",
    "server:dev": "cd server && npm run dev",
    "client": "cd client && npx serve . -p 8080",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "deploy": "cd deploy && bash setup-aws.sh"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
